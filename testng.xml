<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SauceDemo QA Automation Suite" verbose="1" parallel="false">

    <!-- ── SMOKE: Run on every build -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.saucedemo.tests.LoginTest"/>
            <class name="com.saucedemo.tests.InventoryTest"/>
            <class name="com.saucedemo.tests.CartTest"/>
            <class name="com.saucedemo.tests.ProductDetailTest"/>
            <class name="com.saucedemo.tests.CheckoutTest"/>
        </classes>
    </test>

    <!-- ── REGRESSION: Full suite -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
                <include name="functional"/>
            </run>
        </groups>
        <classes>
            <class name="com.saucedemo.tests.LoginTest"/>
            <class name="com.saucedemo.tests.InventoryTest"/>
            <class name="com.saucedemo.tests.CartTest"/>
            <class name="com.saucedemo.tests.ProductDetailTest"/>
            <class name="com.saucedemo.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>
